pipeline {
    agent any

    tools {
        nodejs 'node22'
    }
    
    environment {
        SCANNER_HOME = tool 'sonar-scanner'   // tool
    }
    
    stages {
        
        stage('Git Checkout') {
            steps {
                git credentialsId: 'github-cred', url: 'https://github.com/awais684/3-tier-devops-project.git'
            }
        }
        
        stage('Install Package Dependencies') {
            steps {
                sh "npm install"
            }
        }
        
        stage('Unit Tests') {
            steps {
                sh "npm test"
            }
        }
        
        stage('Trivy FS Scan') {
            steps {
                // sh "trivy fs --format table ."    read it directly in Jenkins console (no file needed)
                 sh "trivy fs --format table -o trivy-report.html ."
                 archiveArtifacts artifacts: 'trivy-report.html', fingerprint: true
            }
        }
        
        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonar') {    // system
                    sh "$SCANNER_HOME/bin/sonar-scanner -Dsonar.projectKey=Campground -Dsonar.projectName=Campground"   // in the next step, you can add a stage for Sonar quality gate check for proper setup
                }
            }
        }
        
        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh 'echo $PASS | docker login -u $USER --password-stdin'
                }
            }
        }
        
        stage('Docker Build & Tag') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                        sh "docker build -t awais684/camp:latest ."                        // or you can run docker build -t awais684/camp:${BUILD_NUMBER} (it will keep build versions)
                    }
                }
            }
        }
        
        stage('Trivy Image Scan') {
            steps {
                sh "trivy image --format table -o trivy-image-report.html awais684/camp:latest"
                archiveArtifacts artifacts: 'trivy-image-report.html', fingerprint: true
            }
        }
        
        stage('Docker Push Image') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                        sh "docker push awais684/camp:latest"
                    }
                }
            }
        }

        stage('Deploy to EKS & Verify') {
    steps {
        withCredentials([
            string(credentialsId: 'aws-access-key', variable: 'AWS_ACCESS_KEY_ID'),
            string(credentialsId: 'aws-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
        ]) {
            sh "aws eks update-kubeconfig --name cluster-1 --region us-east-1"
            sh "kubectl apply -f Manifests/dss.yml --validate=false"
            sh "kubectl get deployment -n webapps"
            sh "kubectl get pods -n webapps"
        }
    }
}
    }

    post {
        success {
            mail(
                to: 'awaiszahid684@gmail.com',
                subject: "✅ CD Pipeline Passed — Build #${env.BUILD_NUMBER} Deployed to EKS",
                body: """\
Hi Team,
The application has been successfully deployed to EKS.

Deployment Details:
──────────────────────────────
Job Name     : ${env.JOB_NAME}
Build Number : #${env.BUILD_NUMBER}
Docker Image : awais684/camp:${env.BUILD_NUMBER}
Namespace    : production
Cluster      : your-eks-cluster-name

                """.stripIndent()
            )
        }

        failure {
            mail(
                to: 'awaiszahid684@gmail.com',
                subject: "❌ CD Pipeline FAILED — Build #${env.BUILD_NUMBER}",
                body: """\
Hi Team,
The CD pipeline has FAILED. Deployment to EKS was not completed.

Build Details:
──────────────────────────────
Job Name     : ${env.JOB_NAME}
Build Number : #${env.BUILD_NUMBER}
Branch       : ${env.GIT_BRANCH}
Build URL    : ${env.BUILD_URL}

                """.stripIndent()
            )
        }

        always {
            sh "docker rmi awais684/camp:${BUILD_NUMBER} || true"
        }
    }
}
